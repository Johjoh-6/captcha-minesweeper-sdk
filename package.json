{
	"name": "captcha-sweeper-sdk",
	"version": "1.0.0",
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/captcha-sweeper.umd.js",
	"module": "./dist/captcha-sweeper.es.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/captcha-sweeper.es.js",
			"require": "./dist/captcha-sweeper.umd.js"
		}
	},
	"scripts": {
		"dev": "vite",
		"demo": "vite --open demo/index.html",
		"build": "vite build",
		"build:demo": "vite build --config vite.demo.config.ts",
		"preview": "vite preview",
		"preview:demo": "vite preview --config vite.demo.config.ts",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"svelte": "^5.0.0-next.1",
		"typescript": "^5.0.0",
		"vite": "^5.0.0"
	}
}
